{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022", "DOM"],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"sourceMap": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		// TS6 no longer auto-includes every @types/* package as ambient globals,
		// so list the ones we rely on globally: node (process, NodeJS, node:*) and
		// jest (describe/it/expect). Import-based types (react, react-dom, vscode)
		// still resolve through their import statements and don't belong here.
		"types": ["node", "jest"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
